# Copy this to .env and fill in your values
# Never commit .env to git

# ── Omada controller ──────────────────────────────
OMADA_BASE_URL=https://your-controller-ip:8043
OMADA_CONTROLLER_ID=your-omadac-id         # Omada web UI → Settings → Controller ID
OMADA_SITE_ID=default                       # MSP site ID, or "default" for single-site
OMADA_CLIENT_ID=your-oauth-client-id        # Omada web UI → Settings → Open API
OMADA_CLIENT_SECRET=your-oauth-client-secret
OMADA_PPSK_PROFILE_ID=your-ppsk-profile-id  # Omada web UI → Wireless → PPSK → copy from URL
OMADA_MODE=local                             # "local" for self-hosted, "cloud" for Omada Cloud

# ── Firebase ──────────────────────────────────────
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
